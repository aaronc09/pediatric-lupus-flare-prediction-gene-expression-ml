# Python cache
__pycache__/
*.pyc

# Virtual environment
.venv/

# Jupyter / Colab
.ipynb_checkpoints/

# Mac / system files
.DS_Store

# Logs
*.log

# Temporary scripts
*_colab_run.py


# =========================
# Outputs (ML experiments)
# =========================

# Ignore everything in outputs
outputs/*

# Re-allow folders so Git can traverse
!outputs/
!outputs/ml_outputs/
!outputs/ml_outputs/figures/
!outputs/ml_outputs/figures/**

# =========================
# Data artifacts (large files)
# =========================

outputs/**/*.pkl
outputs/**/*.parquet
outputs/**/*.csv.gz
outputs/**/*.json
